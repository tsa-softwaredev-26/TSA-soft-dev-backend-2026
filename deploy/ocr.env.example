# Spaitra OCR service environment.
# Local dev: copy to repo root as `.ocr.env` or export vars in your shell.
# Server deploy: copy to `/opt/spaitra/.ocr.env`.
#
# Keep this service on localhost unless you have a reason to expose it.

# HTTP bind address for the OCR microservice.
OCR_HOST=127.0.0.1
OCR_PORT=8001

# PaddleOCR language pack. Use `en` unless you intentionally add more OCR
# language support and test it end to end.
OCR_LANG=en

# Drop OCR segments below this confidence threshold.
OCR_MIN_CONFIDENCE=0.3

# Angle classification adds some extra work. Keep 0 unless rotated text is a
# real problem in your captures.
OCR_USE_ANGLE_CLS=0

# Keep 0 on CPU hosts. Paddle 3.x can crash with MKLDNN enabled on some setups.
OCR_ENABLE_MKLDNN=0

# Pre-resize very large images before OCR to reduce memory pressure.
OCR_MAX_SIDE=2000

# Server-side OCR guardrails.
OCR_REQUEST_TIMEOUT_SECONDS=40
OCR_MAX_CONCURRENCY=1
OCR_THROTTLE_RETRY_AFTER_SECONDS=2

# Must match core API_KEY when set. Protects /ocr from unauthorized local callers.
API_KEY=
