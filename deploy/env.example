# Spaitra core backend environment.
# Local dev: copy to repo root as `.env` or export vars in your shell.
# Server deploy: copy to `/opt/spaitra/.env` and keep real secrets out of git.
#
# Note: this backend does not use `ENV` or `SECRET_KEY`.
# The relevant secret for this service is `API_KEY`.

# API auth secret. Required in production. All routes except /health require
# this value in the X-API-Key header. Replace with a long random string.
API_KEY=replace-with-a-long-random-api-key
# Optional but recommended. Enables SQLCipher encryption for data/memory.db.
# If set, keep this key backed up. Losing it means permanent data loss.
DB_ENCRYPTION_KEY=

# HTTP bind address for the core API. Keep 127.0.0.1 on a server and publish
# through gunicorn + your tunnel or reverse proxy. Local dev can keep these.
API_HOST=127.0.0.1
API_PORT=5000

# Set to 0 to disable the core gunicorn service through config.
# Useful for benchmark windows where you want all GPU memory for offline runs.
ENABLE_CORE_SERVICE=1

# Enable expensive depth estimation. Keep 1 on GPU servers that have room for
# Depth Pro. Set 0 on CPU-only dev machines or low-VRAM servers.
ENABLE_DEPTH=1

# Optional override for depth checkpoint path used by API and benchmarks.
# If empty, defaults to <repo>/checkpoints/depth_pro.pt.
DEPTH_CHECKPOINT_PATH=

# Enable OCR calls from the core backend. Set 0 if you want the backend to run
# without the OCR microservice.
ENABLE_OCR=1

# URL for the separate OCR service. Local dev and single-host production should
# usually keep this on localhost.
OCR_SERVICE_URL=http://127.0.0.1:8001/ocr

# Timeout for one OCR request from the core backend to the OCR service.
OCR_TIMEOUT_SECONDS=10.0

# Deduplicate overlapping scan detections before returning matches.
ENABLE_DEDUP=1

# Enable the learned projection head during scan mode.
ENABLE_LEARNING=1

# GPU memory management. Set 1 on GPUs with less than 8 GB VRAM (e.g. GTX 1060 6 GB).
# When enabled, models are moved between CPU RAM and GPU as each pipeline runs.
# Remember mode: parks YOLOE + Depth Pro on CPU. Scan mode: parks GroundingDINO.
# Tradeoff: ~1-5 s extra latency per pipeline switch (PCIe transfer, not disk reload).
# Shared models (DINOv3, CLIP) stay on GPU at all times.
SAVE_VRAM=0

# Optional: URL that the /debug/state endpoint will probe to check OCR health.
# Leave empty to skip the OCR health probe.
OCR_HEALTH_URL=

# Ollama LLM — used by /ask and /item/ask for natural language query parsing.
# The backend works without Ollama (falls back to embedding-only search).
# Set OLLAMA_HOST if Ollama is not on localhost (e.g. a sidecar container).
# OLLAMA_HOST=http://127.0.0.1:11434
# Seconds to wait for one Ollama response before giving up. Keep this low
# so a stalled Ollama daemon does not add latency to every user request.
OLLAMA_TIMEOUT_SECONDS=5.0
