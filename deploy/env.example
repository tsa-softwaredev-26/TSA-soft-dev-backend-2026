# Copy to /opt/spaitra/.env and fill in values.
# All vars are optional except API_KEY (recommended for production).

# Auth - set a strong secret; all routes except /health require X-API-Key header
API_KEY=changeme

# Disable heavy models to reduce startup time and VRAM usage.
# Depth Pro requires ~2GB VRAM. All models together require ~4GB VRAM per worker.
# Disable if the server has no GPU or less than 4GB VRAM.
ENABLE_DEPTH=1

# OCR is handled by an external HTTP microservice
ENABLE_OCR=1
OCR_SERVICE_URL=http://127.0.0.1:8001/ocr

# Personalization projection head
ENABLE_LEARNING=1
