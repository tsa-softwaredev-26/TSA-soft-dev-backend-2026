import torch
from PIL import Image
from transformers import DepthProImageProcessorFast, DepthProForDepthEstimation
import matplotlib.pyplot as plt
import numpy as np
from pathlib import Path
from object_detection import GroundingDinoDetector
from utils import load_image
CURRENT_DIR = Path(__file__).parent

# Configure your test image and prompt
IMAGE_PATH = CURRENT_DIR / "input_images" / "depth_image.png"
PROMPT = "small round earbud case"

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

# Load your image
image = Image.open(IMAGE_PATH).convert("RGB")

# Load DepthPro model and processor
image_processor = DepthProImageProcessorFast.from_pretrained("apple/DepthPro-hf")
model = DepthProForDepthEstimation.from_pretrained("apple/DepthPro-hf").to(device)

# Optional: pass focal length in pixels if KMP provides it
# fx_px = focal_length_from_kmp
# inputs = image_processor(images=image, focal_length=fx_px, return_tensors="pt").to(device)

inputs = image_processor(images=image, return_tensors="pt").to(device)

# Run inference
with torch.no_grad():
    outputs = model(**inputs)

# Post-process to match original image size
post_processed_output = image_processor.post_process_depth_estimation(
    outputs, target_sizes=[(image.height, image.width)]
)

# Extract outputs
field_of_view = post_processed_output[0]["field_of_view"]
focal_length_px = post_processed_output[0]["focal_length"]
depth_map = post_processed_output[0]["predicted_depth"]  # metric depth in meters

# --- Create a visual (0-255) ---
depth_vis = (depth_map - depth_map.min()) / (depth_map.max() - depth_map.min())
depth_vis = (depth_vis * 255).cpu().numpy().astype("uint8")
depth_vis_image = Image.fromarray(depth_vis)

# Save visual image
depth_vis_image.save("depth_visual.png")

# Optional: display visual inline
plt.imshow(depth_vis_image, cmap="plasma")
plt.title("Depth Visualization")
plt.axis("off")
plt.show()

# Metric depth ready for computations
depth_map_cpu = depth_map.cpu().numpy()

print("Depth map shape (meters):", depth_map_cpu.shape)
print("Field of view (degrees):", field_of_view)
print("Focal length (pixels):", focal_length_px)

# Example bounding box
detector = GroundingDinoDetector()
detection = detector.detect(image, PROMPT)
bbx = detection["box"]

x1, y1, x2, y2 = [int(x) for x in bbx]
x1 = max(0, min(x1, depth_map_cpu.shape[1]-1))
y1 = max(0, min(y1, depth_map_cpu.shape[0]-1))
x2 = max(0, min(x2, depth_map_cpu.shape[1]-1))
y2 = max(0, min(y2, depth_map_cpu.shape[0]-1))

depth_crop = depth_map_cpu[y1:y2, x1:x2]

distance_m = np.median(depth_crop)

print(distance_m)