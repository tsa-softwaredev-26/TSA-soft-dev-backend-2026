import torch
from PIL import Image
from transformers import DepthProImageProcessorFast, DepthProForDepthEstimation
import numpy as np
from pathlib import Path
from utils import load_image
from object_detection import GroundingDinoDetector
import matplotlib.pyplot as plt

# -------------------------------
# Config
# -------------------------------
CURRENT_DIR = Path(__file__).parent
IMAGE_PATH = CURRENT_DIR / "input_images/depth_image.png"
PROMPT = "small round earbud case"
PAD = 50  # padding around bbox

# -------------------------------
# Device
# -------------------------------
device = torch.device("mps") if torch.backends.mps.is_available() else "cpu"
print(f"Using device: {device}")

# -------------------------------
# Load Image
# -------------------------------
image = load_image(IMAGE_PATH)
orig_width, orig_height = image.size

# -------------------------------
# Step 1: Detect Object
# -------------------------------
detector = GroundingDinoDetector()
detection = detector.detect(image, PROMPT)

if detection is None:
    print("❌ Object not detected")
    exit()

print(f"✅ Detected: {detection['label']} (confidence: {detection['score']:.2f})")
x1, y1, x2, y2 = [int(v) for v in detection["box"]]

# -------------------------------
# Step 2: Crop Full-Res Context Around Object
# -------------------------------
x1_pad = max(0, x1 - PAD)
y1_pad = max(0, y1 - PAD)
x2_pad = min(orig_width, x2 + PAD)
y2_pad = min(orig_height, y2 + PAD)

cropped_context = image.crop((x1_pad, y1_pad, x2_pad, y2_pad))
crop_width, crop_height = cropped_context.size
print(f"📐 Cropped context: {crop_width}x{crop_height}")

# -------------------------------
# Step 3: DepthPro on Cropped Context
# -------------------------------
image_processor = DepthProImageProcessorFast.from_pretrained("apple/DepthPro-hf")
model = DepthProForDepthEstimation.from_pretrained("apple/DepthPro-hf").to(device)

inputs = image_processor(images=cropped_context, return_tensors="pt").to(device)

with torch.no_grad(), torch.autocast(device_type="mps"):
    outputs = model(**inputs)

post_processed = image_processor.post_process_depth_estimation(
    outputs, target_sizes=[(crop_height, crop_width)]
)

depth_crop = post_processed[0]["predicted_depth"]
focal_length_px = post_processed[0]["focal_length"]

# -------------------------------
# Step 4: Map original bbox into cropped context
# -------------------------------
bbox_in_crop = (
    x1 - x1_pad,
    y1 - y1_pad,
    x2 - x1_pad,
    y2 - y1_pad
)

# Clip to crop dimensions
bbox_in_crop = (
    max(0, bbox_in_crop[0]),
    max(0, bbox_in_crop[1]),
    min(depth_crop.shape[1]-1, bbox_in_crop[2]),
    min(depth_crop.shape[0]-1, bbox_in_crop[3])
)

# Extract depth region
object_depth_region = depth_crop[
    bbox_in_crop[1]:bbox_in_crop[3],
    bbox_in_crop[0]:bbox_in_crop[2]
].cpu().numpy()

distance_m = np.median(object_depth_region)
distance_ft = distance_m * 3.28084

# -------------------------------
# Results
# -------------------------------
print("\n" + "="*50)
print(f"🎯 Object: {detection['label']}")
print(f"📊 Confidence: {detection['score']:.2f}")
print(f"📍 BBox (original image coords): [{x1}, {y1}, {x2}, {y2}]")
print(f"📏 Estimated Distance: {distance_m:.2f} m ({distance_ft:.1f} ft)")
print(f"🔭 Focal length: {focal_length_px:.0f}px")
print("="*50)

# -------------------------------
# Optional: Visualization
# -------------------------------
depth_vis = (depth_crop - depth_crop.min()) / (depth_crop.max() - depth_crop.min())
depth_vis = (depth_vis * 255).cpu().numpy().astype("uint8")

plt.figure(figsize=(12, 5))
plt.subplot(1, 2, 1)
plt.imshow(cropped_context)
plt.title("Cropped Context")
plt.axis("off")

plt.subplot(1, 2, 2)
plt.imshow(depth_vis, cmap="plasma")
plt.title("Depth Map (Cropped Context)")
rect = plt.Rectangle(
    (bbox_in_crop[0], bbox_in_crop[1]),
    bbox_in_crop[2] - bbox_in_crop[0],
    bbox_in_crop[3] - bbox_in_crop[1],
    fill=False, edgecolor='red', linewidth=2
)
plt.gca().add_patch(rect)
plt.axis("off")

plt.tight_layout()
plt.show()